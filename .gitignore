# env — .env holds the 4 Groq keys; never commit it
.venv/
.env

# python
__pycache__/
*.pyc
.pytest_cache/

# local model / qdrant caches
.cache/
qdrant_storage/
traces/

# --- run traces -------------------------------------------------------------------
# Keep the EVIDENCE, skip the bulk. Every number in EXPERIMENTS.md is backed by a
# runs/<id>/eval/scores.json, and those are ~100 KB each; the full per-query traces are
# tens of MB because each one embeds the text of 20 retrieved chunks.
#
# Rule of thumb: commit a trace only if it is expensive to reproduce.
#   retrieval-only runs -> regenerate free in ~30s (`harness --retrieve-only`)
#   generated runs      -> cost real tokens against a 100k/day/key/model quota
runs/*
!runs/index.jsonl
!runs/*/
!runs/*/manifest.json
!runs/*/queries.jsonl
!runs/*/eval/
!runs/*/eval/**

# Full per-query traces: excluded by default (bulk, and usually reproducible)…
runs/*/queries/

# …except the E0 baseline run. Its 60 answers cost ~142k tokens and are the only real
# generated answers in the repo (the frontend's demo data + the judged panel's evidence).
# Losing them means re-spending the budget to get them back.
!runs/20260718-151413-4593/queries/
!runs/20260718-151413-4593/queries/**
